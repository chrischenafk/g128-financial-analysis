# ─────────────────────────────────────────────────────────────
# g128-financial-analysis — environment template
#
# Copy to `.env` and fill in real values.  NEVER commit `.env`.
#   cp .env.example .env        (Windows: copy .env.example .env)
# ─────────────────────────────────────────────────────────────

# Claude Platform API key for the external pm-analysis-code-supplement
# skill. Leave blank until the skill is configured — the pipeline runs
# fully with the LLM step stubbed and only needs this for the real call.
ANTHROPIC_API_KEY=

# Claude model string for the skill call. Intentionally left blank —
# do NOT hardcode a model here; it is filled in when the Claude
# Platform skill is wired up (last build layer).
CLAUDE_MODEL=

# Logging verbosity for the run: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO