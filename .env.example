# ─────────────────────────────────────────────────────────────
# g128-financial-analysis — environment template
#
# Copy to `.env` and fill in real values.  NEVER commit `.env`.
#   cp .env.example .env        (Windows: copy .env.example .env)
# ─────────────────────────────────────────────────────────────

# Claude Platform API key for the external pm-analysis-code-supplement
# skill. Leave blank until the skill is configured — the pipeline runs
# fully with the LLM step stubbed and only needs this for the real call.
ANTHROPIC_API_KEY=

# Claude model for the skill call. Leave blank to use claude-sonnet-4-6 (default, recommended).
# Set to claude-opus-4-8 only for testing — Opus costs ~5x more per token.
CLAUDE_MODEL=

# pm-analysis-code-supplement skill (Skills API). SKILL_ID is the
# skill identifier from the Claude Platform (e.g. skill_01...). The
# report layer fails fast if it is unset. Pin SKILL_VERSION to a
# specific version in production; "latest" is the default for dev.
SKILL_ID=
SKILL_VERSION=latest

# Logging verbosity for the run: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO