# ─────────────────────────────────────────────────────────────
# Secrets & environment  (never commit)
# ─────────────────────────────────────────────────────────────
.env
.env.*
# ...but the placeholder template IS tracked:
!.env.example

# ─────────────────────────────────────────────────────────────
# Real company data & all generated output  (never commit)
#   Confidential financial workbooks, the local history store,
#   generated analysis packages, reports, and run logs.
# ─────────────────────────────────────────────────────────────
data/raw/
#Make exception for report context file
!data/raw/report_context.md
data/processed/
output/
logs/

# ─────────────────────────────────────────────────────────────
# Real data / document formats  (safety net in case a file
#   ever lands outside the ignored folders above)
# ─────────────────────────────────────────────────────────────
*.xlsm
*.xlsx
*.csv
*.docx
*.pdf
*.sqlite

# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
.pytest_cache/
.venv/
venv/

# ─────────────────────────────────────────────────────────────
# OS / editor cruft
# ─────────────────────────────────────────────────────────────
.DS_Store
.cursor/
.claude/

# ─────────────────────────────────────────────────────────────
# Batch scripts
# ─────────────────────────────────────────────────────────────
run_report.bat

# ─────────────────────────────────────────────────────────────
# NOTE: .md docs, .env.example, and everything under src/, tests/,
# and docs/ are intentionally tracked.
#
# Sanitized/synthetic SAMPLE data — if we ever need it for tests or
# examples — goes in a dedicated top-level  sample_data/  folder
# (never copied from real company files) and would be added with an
# explicit  `git add -f sample_data/...`  to override the format
# ignores above. Real workbooks stay in data/raw/ and never tracked.
# ─────────────────────────────────────────────────────────────