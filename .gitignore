# ─────────────────────────────────────────────────────────────
# Environments & secrets  (never commit)
# ─────────────────────────────────────────────────────────────
.env
.env.local
.env.*
!.env.example
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/
secrets.json
config/secrets.yaml
credentials.json

# ─────────────────────────────────────────────────────────────
# Real company data & all generated output  (never commit)
#   These folders hold confidential financial data, the local
#   history store, generated analysis packages, reports, and logs.
# ─────────────────────────────────────────────────────────────
data/raw/
data/processed/
output/
logs/

# ─────────────────────────────────────────────────────────────
# Data / workbook file types  (belt-and-suspenders safety net
#   in case a file lands outside the ignored folders above)
# ─────────────────────────────────────────────────────────────
*.xlsm
*.xlsx
*.xls
*.csv
*.json
*.xml
*.sqlite
*.db
*.db3

# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─────────────────────────────────────────────────────────────
# Editors / OS cruft
# ─────────────────────────────────────────────────────────────
.cursor/
.vscode/
.idea/
.DS_Store
Thumbs.db